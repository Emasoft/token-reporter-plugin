#!/usr/bin/env bash
# Pre-push hook — quality gate before code reaches GitHub.
# Blocks the push if there are uncommitted changes or lint errors.
# Does NOT modify the repo — no commits, no version bumps, no tags.
#
# Install: ln -sf ../../scripts/pre-push .git/hooks/pre-push
set -euo pipefail

# Resolve repo root (works from .git/hooks/, scripts/hooks/, or direct invocation)
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

PUSHING_TO_MAIN=0
while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "$remote_ref" == "refs/heads/main" ]]; then
    PUSHING_TO_MAIN=1
  fi
done

# Only gate pushes to main
if [ "$PUSHING_TO_MAIN" = "0" ]; then
  exit 0
fi

echo ""
echo "========================================"
echo "  Pre-push quality gate"
echo "========================================"
echo ""

# ── 0. Clean working tree ─────────────────────────────────
echo "── 0. Clean working tree ──"
if ! git diff --quiet || ! git diff --cached --quiet; then
  echo ""
  echo "BLOCKED: uncommitted changes found. Commit or stash before pushing."
  git status --short
  exit 1
fi
echo "OK: working tree clean"
echo ""

# ── 1. Lint ──────────────────────────────────────────────
echo "── 1. Lint ──"
uvx ruff check scripts/token-reporter.py || {
  echo ""; echo "BLOCKED: ruff check failed."; exit 1
}
uvx ruff format --check scripts/token-reporter.py || {
  echo ""; echo "BLOCKED: ruff format check failed. Run: uvx ruff format scripts/token-reporter.py"; exit 1
}
echo "OK: lint passed"
echo ""

# ── 2. Syntax check ─────────────────────────────────────
echo "── 2. Syntax check ──"
python3 -m py_compile scripts/token-reporter.py || {
  echo ""; echo "BLOCKED: syntax error in token-reporter.py"; exit 1
}
echo "OK: syntax valid"
echo ""

# ── 3. Plugin manifest check ────────────────────────────
echo "── 3. Plugin manifest ──"
python3 -c "import json; json.load(open('.claude-plugin/plugin.json'))" || {
  echo ""; echo "BLOCKED: plugin.json is not valid JSON"; exit 1
}
echo "OK: plugin.json valid"
echo ""

echo "========================================"
echo "  All checks passed — pushing"
echo "========================================"
echo ""

exit 0
